        </property>
        <item>
         <widget class="QCheckBox" name="claudeEnabledCheckBox">
          <property name="text">
           <string>Monitor Claude Code quota</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>Poll the Claude API for your 5-hour session and 7-day rolling quota usage and show them as tray icons.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="agEnabledCheckBox">
          <property name="text">
           <string>Monitor AntiGravity quota (auto-detect)</string>
          </property>
          <property name="checked">
           <bool>true</bool>
          </property>
          <property name="toolTip">
           <string>Poll the AntiGravity API for per-model quota usage. AntiGravity is detected automatically — disable this if you don't use AntiGravity or want to reduce API calls.</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
