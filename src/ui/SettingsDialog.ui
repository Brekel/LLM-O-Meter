      <widget class="QLabel" name="tokenLabel">
       <property name="text">
        <string>Claude Bearer Token:</string>
       </property>
       <property name="toolTip">
        <string>OAuth bearer token used to authenticate with the Claude API. Leave empty to use the token from the Claude Code credentials file (~/.claude/.credentials.json).</string>
