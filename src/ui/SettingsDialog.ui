         <widget class="QCheckBox" name="hideZeroIconsCheckBox">
          <property name="text">
           <string>Hide icons at 0% utilization</string>
          </property>
          <property name="toolTip">
           <string>Hide tray icons for quotas that are at 0% — for example at the start of a new session before any usage has been recorded.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="showRateEstimatesCheckBox">
          <property name="text">
           <string>Show rate estimates in tooltips and popup</string>
          </property>
          <property name="toolTip">
           <string>When enabled, tooltips and the popup window show a "~exhausted in Xh Ym" estimate based on your recent usage rate. Only shown when the quota is on track to run out before it resets.</string>
          </property>
         </widget>
        </item>
       </layout>
